# LearnedDBComponentsLLM - Environment Configuration
# Copy this file to .env and fill in your actual values.

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=imdb
DB_USER=postgres
DB_PASSWORD=admin

# ── LLM / Ollama ─────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
# Space or comma-separated list of models to run
MODELS=llama3.2

# Model used for fixing broken queries (can differ from generation model)
FIX_MODEL=llama3
FIX_TEMPERATURE=0.0

# ── Generation Pipeline ──────────────────────────────────
TEMPERATURE=0.8
BATCH_SIZE=10
TOTAL_QUERIES=100
OUTPUT_FOLDER=output
SCHEMA_FILE=schema/IMDB_schema.txt

# ── Training Pipeline ────────────────────────────────────
NUM_MATERIALIZED_SAMPLES=1000
HIDDEN_UNITS=256
LEARNING_RATE=0.0001
AL_ROUNDS=5
AL_ACQUIRE=200
AL_EPOCHS=10

# ── Database Execution ───────────────────────────────────
DB_TIMEOUT=6000
MAX_DB_RETRIES=2
DB_THROTTLE_SEC=0.5
DB_ERROR_BACKOFF_SEC=3.0
MAX_FIX_ITERATIONS=3
